{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SyncLan",
  "version": "0.1.0-rc.2",
  "identifier": "io.github.1111mp.synclan",
  "build": {
    "beforeDevCommand": "pnpm app:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm app:build",
    "frontendDist": "../dist/ui",
    "removeUnusedCommands": true
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": {
        "default-src": "'self' blob: data: filesystem: asset: tauri: http: https: ws: wss:",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "style-src-elem": "'self' 'unsafe-inline'",
        "style-src-attr": "'self' 'unsafe-inline'",
        "img-src": "'self' blob: data: asset: tauri: http: https:",
        "font-src": "'self' data: asset: tauri:",
        "connect-src": "'self' ipc: tauri: asset: http://asset.localhost http://ipc.localhost http: https: ws: wss:"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$RESOURCE/../**", "**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/IconAssets.car"
    ],
    "resources": [
      "resources",
      "resources/web/*",
      "resources/migrations/*",
      "icons/icon.png"
    ],
    "publisher": "Synclan",
    "copyright": "MIT License",
    "licenseFile": "../LICENSE",
    "license": "MIT",
    "category": "SocialNetworking",
    "shortDescription": "Local network chat and file transfer",
    "longDescription": "SyncLan is a cross-platform utility for chatting and transferring files between devices on the same local network.",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlENDExMTIzQzEwMzg4RDMKUldUVGlBUEJJeEZCblRvbml1YmFGcXJQNnFJNFIwa0I1WWNnemphUkpLUEFOTjNsKzQ2QVFVSGcK",
      "endpoints": [
        "https://github.com/1111mp/synclan/releases/download/updater/update.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
